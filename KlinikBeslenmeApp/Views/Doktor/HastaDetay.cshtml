@model List<KlinikBeslenmeApp.Controllers.DoktorHastaDetayViewModel>
@{
    Layout = "_Layout";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark"><i class="bi bi-clipboard2-pulse text-primary"></i> @ViewBag.HastaAd - Beslenme Raporu</h3>
        <a asp-action="AdminPanel" class="btn btn-outline-secondary fw-bold shadow-sm"><i class="bi bi-arrow-left"></i> Hastalarıma Dön</a>
    </div>

    <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
        <div class="card-body bg-light" style="border-radius: 15px;">
            <form method="get" asp-action="HastaDetay" class="row align-items-end">
                <input type="hidden" name="id" value="@ViewBag.HastaId" />
                <div class="col-md-4">
                    <label class="fw-bold text-muted mb-1">Görüntülenecek Tarih</label>
                    <input type="date" name="filtreTarih" class="form-control form-control-lg shadow-sm" value="@ViewBag.SeciliTarih" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow"><i class="bi bi-search"></i> Kayıtları Getir</button>
                </div>
            </form>
        </div>
    </div>
    @if (TempData["BasariMesaji"] != null)
    {
        <div class="alert alert-success fw-bold text-center shadow-sm mb-4"><i class="bi bi-check-circle-fill"></i> @TempData["BasariMesaji"]</div>
    }

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0" style="border-radius: 15px; border-left: 5px solid #6f42c1 !important;">
                <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-chat-square-text-fill" style="color: #6f42c1;"></i> Diyetisyen / Doktor Notu & Hedefler</h5>
                </div>
                <div class="card-body bg-light">
                    <form asp-action="DoktorNotuKaydet" method="post">
                        <input type="hidden" name="HastaId" value="@ViewBag.HastaId" />

                        <div class="row mb-3">
                            <div class="col-md-8 mb-3 mb-md-0">
                                <label class="form-label text-muted fw-bold">Hastaya Özel Tavsiye ve Notlar</label>
                                <textarea name="DoktorNotu" class="form-control shadow-sm border-0" rows="3" placeholder="Örn: Günlük suyunu ihmal etme, akşamları yürüyüş yap...">@ViewBag.DoktorNotu</textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted fw-bold">Günlük Kalori Hedefi</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white border-0 text-danger"><i class="bi bi-fire"></i></span>
                                    <input type="number" name="GunlukKaloriHedefi" class="form-control border-0 form-control-lg fw-bold text-dark" value="@ViewBag.GunlukKaloriHedefi" placeholder="Örn: 1800" />
                                    <span class="input-group-text bg-white border-0 fw-bold text-muted">kcal</span>
                                </div>
                                <div class="form-text text-muted small mt-2"><i class="bi bi-info-circle"></i> Hastanın aşmaması gereken kalori sınırını belirleyin.</div>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary fw-bold shadow-sm px-4" style="background-color: #6f42c1; border: none; border-radius: 10px;">
                                <i class="bi bi-save"></i> Hedefleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow border-0" style="border-radius: 15px;">
        <div class="card-header bg-primary text-white p-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-list-check"></i> @Convert.ToDateTime(ViewBag.SeciliTarih).ToString("dd.MM.yyyy") Tarihli Tüketimler</h5>
        </div>
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card shadow border-0" style="border-radius: 15px; border-left: 5px solid #0dcaf0 !important;">
                    <div class="card-header bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-activity text-info"></i> Fiziksel Gelişim ve Kilo Trendi</h5>
                        <span class="badge bg-info text-dark rounded-pill fs-6 shadow-sm">Güncel Kilo: @ViewBag.GuncelKilo kg</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 text-center">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th>Tartılma Tarihi</th>
                                        <th>Kilo (kg)</th>
                                        <th>Durum (Trend)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.KiloGecmisi == null || ((List<KlinikBeslenmeApp.Models.TblKiloGecmisi>)ViewBag.KiloGecmisi).Count == 0)
                                    {
                                        <tr><td colspan="3" class="py-4 text-muted fw-bold">Henüz kilo geçmişi kaydı bulunmuyor. Hastanın profilini güncellemesi bekleniyor.</td></tr>
                                    }
                                    else
                                    {
                                        var kiloListesi = (List<KlinikBeslenmeApp.Models.TblKiloGecmisi>)ViewBag.KiloGecmisi;
                                        for (int i = 0; i < kiloListesi.Count; i++)
                                        {
                                            var anlikKilo = kiloListesi[i];
                                            string trend = "-";
                                            string renk = "text-muted";
                                            string ikon = "bi-dash";

                                            if (i < kiloListesi.Count - 1)
                                            {
                                                var eskiKilo = kiloListesi[i + 1];
                                                if (anlikKilo.Kilo < eskiKilo.Kilo) { trend = "Kilo Vermiş (Başarılı)"; renk = "text-success"; ikon = "bi-arrow-down-circle-fill"; }
                                                else if (anlikKilo.Kilo > eskiKilo.Kilo) { trend = "Kilo Almış (Dikkat)"; renk = "text-danger"; ikon = "bi-arrow-up-circle-fill"; }
                                                else { trend = "Kilosunu Korumuş"; renk = "text-warning"; ikon = "bi-dash-circle-fill"; }
                                            }

                                            <tr>
                                                <td class="text-muted"><i class="bi bi-calendar-event"></i> @anlikKilo.TartilmaTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                                <td class="fw-bold fs-5 text-dark">@anlikKilo.Kilo kg</td>
                                                <td class="fw-bold @renk"><i class="bi @ikon"></i> @trend</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Öğün</th>
                            <th>Yemek Adı</th>
                            <th>Porsiyon</th>
                            <th>Saat</th>
                            <th>Not / Açıklama</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr><td colspan="5" class="text-center py-5 text-muted fw-bold">Bu tarihte hastaya ait herhangi bir beslenme kaydı bulunamadı.</td></tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-primary">@item.OgunTipi</td>
                                    <td class="fw-bold text-dark">@item.YemekAdi</td>
                                    <td><span class="badge bg-secondary rounded-pill fs-6">@item.Porsiyon Porsiyon</span></td>
                                    <td class="text-muted"><i class="bi bi-clock"></i> @item.TuketimTarihi.ToString("HH:mm")</td>
                                    <td class="text-muted fst-italic">@(string.IsNullOrEmpty(item.Aciklama) ? "-" : item.Aciklama)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>