@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Doktor Girişi - Klinik Beslenme Sistemi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background-color: #f4f6f9; display: flex; align-items: center; justify-content: center; height: 100vh; animation: fadeIn 0.6s ease-in-out; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        .login-card { border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: none; overflow: hidden; }
        .login-header { background: linear-gradient(135deg, #0d6efd, #0a58ca); color: white; padding: 30px; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card login-card">
                    <div class="login-header">
                        <i class="bi bi-heart-pulse" style="font-size: 3rem;"></i>
                        <h3 class="mt-2 fw-bold">Doktor / Diyetisyen Paneli</h3>
                        <p class="mb-0 text-light">Yönetim sistemine giriş yapın</p>
                    </div>
                    <div class="card-body p-4 p-sm-5">

                        @if (ViewBag.Hata != null)
                        {
                            <div class="alert alert-danger text-center fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Hata</div>
                        }

                        <form asp-controller="Doktor" asp-action="GirisYap" method="post">
                            <div class="mb-4">
                                <label class="fw-bold text-muted mb-1">E-Posta Adresi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-envelope-fill text-primary"></i></span>
                                    <input type="email" name="Email" class="form-control form-control-lg bg-light" placeholder="doktor@klinik.com" required />
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="fw-bold text-muted mb-1">Şifre</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-lock-fill text-primary"></i></span>
                                    <input type="password" name="Sifre" class="form-control form-control-lg bg-light" placeholder="••••••••" required />
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">Giriş Yap <i class="bi bi-box-arrow-in-right"></i></button>
                        </form>

                        <div class="text-center mt-4">
                            <a href="/Home/GirisYap" class="text-decoration-none text-muted"><i class="bi bi-arrow-left-circle"></i> Hasta Girişine Dön</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>