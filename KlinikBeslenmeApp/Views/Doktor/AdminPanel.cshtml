@{
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center bg-primary text-white p-4 shadow-sm" style="border-radius: 15px;">
            <div>
                <h2 class="mb-0 fw-bold"><i class="bi bi-heart-pulse"></i> Klinik Yönetim Paneli</h2>
                <p class="mb-0 opacity-75">Sisteme hoş geldiniz. Buradan hastalarınızı yönetebilirsiniz.</p>
            </div>
            <div>
                <a asp-controller="Doktor" asp-action="CikisYap" class="btn btn-light text-danger fw-bold shadow-sm"><i class="bi bi-power"></i> Çıkış Yap</a>
            </div>
        </div>
    </div>

    @if (TempData["Mesaj"] != null)
    {
        <div class="alert alert-success fw-bold text-center shadow-sm"><i class="bi bi-check-circle-fill"></i> @TempData["Mesaj"]</div>
    }

    <div class="row">
        <div class="col-md-12">
            <div class="card shadow border-0" style="border-radius: 15px;">
                <div class="card-header bg-white border-bottom p-4">
                    <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-people-fill text-primary"></i> Kayıtlı Hastalar</h4>
                </div>
                <div class="card-body p-5 text-center">
                    <i class="bi bi-hourglass-split text-muted" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-muted fw-bold">Hasta listesi yükleniyor...</h5>
                    <p class="text-muted">Bir sonraki adımda buraya efsanevi hasta yönetim tablosunu inşa edeceğiz!</p>
                </div>
            </div>
        </div>
    </div>
</div>