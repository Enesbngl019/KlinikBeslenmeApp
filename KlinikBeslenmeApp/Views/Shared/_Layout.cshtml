<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KlinikBeslenmeApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KlinikBeslenmeApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm mb-3">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🩺 KlinikBeslenme</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Gıda Veritabanı</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            @if (Context.Session.GetString("KullaniciAd") != null)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning fw-bold" href="/Home/Profilim">👤 Profilim (@Context.Session.GetString("KullaniciAd"))</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger" href="/Home/CikisYap">Çıkış Yap</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" href="/Home/GirisYap">Giriş Yap</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-success fw-bold" href="/Home/KayitOl">Kayıt Ol</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KlinikBeslenmeApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Mesaj"] != null)
    {
        <script>
            Swal.fire({
                title: 'Başarılı!',
                html: '@TempData["Mesaj"]',  // SİHİRLİ KELİME: text yerine html yaptık!
                icon: 'success',
                confirmButtonColor: '#198754',
                confirmButtonText: 'Tamam'
            });
        </script>
    }

    @if (TempData["Hata"] != null)
    {
        <script>
            Swal.fire({
                title: 'Eyvah!',
                html: '@TempData["Hata"]',  // SİHİRLİ KELİME: text yerine html yaptık!
                icon: 'error',
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Tamam'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>