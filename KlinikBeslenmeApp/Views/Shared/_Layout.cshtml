@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AKBİS - Sisteme Giriş</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        .hover-effect {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .hover-effect:hover {
                transform: translateY(-10px);
                box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
                cursor: pointer;
            }
    </style>
</head>
<body class="bg-light">
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <div class="container vh-100 d-flex align-items-center justify-content-center">
        <div class="text-center w-100">
            <h2 class="mb-5 fw-bold text-dark">AKBİS Sistemine Hoş Geldiniz</h2>


            <div class="container mb-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark">Sisteme Giriş Yapın</h2>
                    <p class="text-muted">Lütfen yetkili olduğunuz profili seçerek devam edin.</p>
                </div>
                <div class="row g-4 justify-content-center text-center">

                    <div class="col-md-4">
                        <a href="@Url.Action("GirisYap", "Home")" class="text-decoration-none">
                            <div class="card shadow border-0 p-5 h-100 bg-primary text-white hover-effect rounded-4">
                                <i class="fas fa-user-injured fa-4x mb-3"></i>
                                <h4 class="fw-bold">Hasta Girişi</h4>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="@Url.Action("GirisYap", "Doktor")" class="text-decoration-none">
                            <div class="card shadow border-0 p-5 h-100 bg-success text-white hover-effect rounded-4">
                                <i class="fas fa-user-md fa-4x mb-3"></i>
                                <h4 class="fw-bold">Doktor Girişi</h4>
                            </div>
                        </a>
                    </div>

                    <div class="col-md-4">
                        <a href="#" class="text-decoration-none" onclick="alert('Admin paneli yapım aşamasındadır!');">
                            <div class="card shadow border-0 p-5 h-100 bg-dark text-white hover-effect rounded-4">
                                <i class="fas fa-user-shield fa-4x mb-3"></i>
                                <h4 class="fw-bold">Admin Girişi</h4>
                                <p class="small text-white-50 mt-2 mb-0">(Yakında)</p>
                            </div>
                        </a>
                    </div>

                </div>
            </div>
    </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>