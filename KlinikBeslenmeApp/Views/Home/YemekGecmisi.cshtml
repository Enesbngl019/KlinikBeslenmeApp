@model IEnumerable<KlinikBeslenmeApp.Controllers.YemekGecmisiViewModel>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h2 class="fw-bold text-primary"><i class="bi bi-clock-history"></i> Yemek Geçmişim</h2>
        <a href="@Url.Action("AnaPanel", new { id = ViewBag.HastaId })" class="btn btn-secondary btn-sm shadow-sm">Panoya Dön</a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light" style="border-radius: 10px;">
        <div class="card-body">
            <form asp-action="YemekGecmisi" method="get" class="row align-items-end">
                <input type="hidden" name="id" value="@ViewBag.HastaId" />

                <div class="col-md-4">
                    <label class="fw-bold text-muted mb-1">Tarihe Göre Filtrele:</label>
                    <input type="date" name="filtreTarih" class="form-control" value="@ViewBag.SeciliTarih" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold"><i class="bi bi-search"></i> Getir</button>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-action="YemekGunluguEkle" asp-route-id="@ViewBag.HastaId" class="btn btn-success fw-bold shadow-sm">
                        <i class="bi bi-plus-circle"></i> Yeni Öğün Ekle
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center py-5 border" style="border-radius: 15px;">
            <i class="bi bi-calendar-x display-4 d-block mb-3 text-muted"></i>
            <h5 class="text-muted">Bu tarihte kaydedilmiş herhangi bir öğün bulunamadı.</h5>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var paket in Model.GroupBy(m => m.KayitId))
            {
                var ilkYemek = paket.First(); // Paketin içindeki ilk yemeğin saatini ve öğün tipini başlığa yazmak için alıyoruz

                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-radius: 15px; overflow: hidden;">

                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-3">
                            <div>
                                <i class="bi bi-clock me-1"></i> <span class="fw-bold fs-5">@ilkYemek.TuketimTarihi.Value.ToString("HH:mm")</span>
                                <span class="badge bg-info text-dark ms-2" style="font-size: 0.9rem;">@ilkYemek.OgunTipi</span>
                            </div>
                            <span class="badge bg-secondary">@paket.Count() Çeşit</span>
                        </div>

                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                @foreach (var item in paket)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center p-3 hover-bg-light">
                                        <div>
                                            <h6 class="mb-0 fw-bold text-primary">@item.YemekAdi</h6>
                                            <small class="text-muted"><i class="bi bi-tag"></i> @item.Kategori</small>

                                            @if (!string.IsNullOrEmpty(item.Aciklama))
                                            {
                                                <div class="text-muted small mt-1" style="font-style: italic;">
                                                    <i class="bi bi-chat-left-text"></i> "@item.Aciklama"
                                                </div>
                                            }
                                        </div>

                                        <div>
                                            <form asp-action="YemekGunluguSil" method="post" class="d-inline" onsubmit="return confirm('Bu yemeği silmek istediğine emin misin?');">
                                                <input type="hidden" name="gunlukId" value="@item.GunlukId" />
                                                <input type="hidden" name="hastaId" value="@ViewBag.HastaId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>