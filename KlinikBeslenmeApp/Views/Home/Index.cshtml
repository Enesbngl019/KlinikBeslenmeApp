@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AKBİS - Ana Sayfa</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        .hover-effect {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .hover-effect:hover {
                transform: translateY(-10px);
                box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important;
                cursor: pointer;
            }

        .bg-gradient-green {
            background: linear-gradient(135deg, #198754 0%, #20c997 100%);
        }
    </style>
</head>
<body class="bg-light">

    <!-- TEPE AFİŞ (HERO KISMI) -->
    <div class="container-fluid bg-gradient-green text-white text-center py-5 shadow-sm rounded-bottom mb-5">
        <div class="container py-5">
            <h1 class="display-4 fw-bold mb-3">Klinik Beslenme Bilgi Sistemi</h1>
            <p class="lead mb-4 fw-normal">Uzman diyetisyenler ve hastalar için tasarlanmış, kronik hastalıklara tam uyumlu akıllı menü planlama ve takip otomasyonu.</p>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                <a asp-controller="Home" asp-action="KayitOl" class="btn btn-outline-light btn-lg px-4 fw-bold">
                    <i class="fas fa-user-plus me-2"></i>Yeni Hasta Kaydı
                </a>
            </div>
        </div>
    </div>

    <!-- 3'LÜ GİRİŞ KARTLARI -->
    <div class="container mb-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark">Sisteme Giriş Yapın</h2>
            <p class="text-muted">Lütfen yetkili olduğunuz profili seçerek devam edin.</p>
        </div>
        <div class="row g-4 justify-content-center text-center">

            <!-- HASTA GİRİŞİ -->
            <div class="col-md-4">
                <a href="@Url.Action("GirisYap", "Home")" class="text-decoration-none">
                    <div class="card shadow border-0 p-5 h-100 bg-primary text-white hover-effect rounded-4">
                        <i class="fas fa-user-injured fa-4x mb-3"></i>
                        <h4 class="fw-bold">Hasta Girişi</h4>
                    </div>
                </a>
            </div>

            <!-- DOKTOR GİRİŞİ -->
            <div class="col-md-4">
                <a href="@Url.Action("GirisYap", "Doktor")" class="text-decoration-none">
                    <div class="card shadow border-0 p-5 h-100 bg-success text-white hover-effect rounded-4">
                        <i class="fas fa-user-md fa-4x mb-3"></i>
                        <h4 class="fw-bold">Doktor Girişi</h4>
                    </div>
                </a>
            </div>

            <!-- ADMIN GİRİŞİ (POP-UP KALDIRILDI, DİREKT SİSTEM YÖNETİMİNE GİDER) -->
            <div class="col-md-4">
                <a href="@Url.Action("AdminGiris", "Home")" class="text-decoration-none">
                    <div class="card shadow border-0 p-5 h-100 bg-dark text-white hover-effect rounded-4">
                        <i class="fas fa-user-shield fa-4x mb-3"></i>
                        <h4 class="fw-bold">Admin Girişi</h4>
                    </div>
                </a>
            </div>

        </div>
    </div>

    <!-- SİSTEM ÖZELLİKLERİ BİLGİ KARTLARI -->
    <div class="container mb-5">
        <div class="row text-center">
            <div class="col-12 mb-4 mt-5">
                <h2 class="fw-bold text-secondary">Sistem Özellikleri</h2>
                <p class="text-muted">Gelişmiş veri tabanı altyapısı ile sağlığınız güvende.</p>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm hover-effect rounded-4">
                    <div class="card-body p-4">
                        <div class="display-4 mb-3">🍽️</div>
                        <h5 class="card-title fw-bold text-dark">Zengin Reçete Arşivi</h5>
                        <p class="card-text text-muted">TÜRKOMP verilerine dayalı, gramajı ve makroları hesaplanmış 226'dan fazla standart klinik yemek reçetesi.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm hover-effect rounded-4">
                    <div class="card-body p-4">
                        <div class="display-4 mb-3">🩺</div>
                        <h5 class="card-title fw-bold text-dark">Klinik Kısıtlamalar</h5>
                        <p class="card-text text-muted">Çölyak, diyabet ve hipertansiyon gibi kronik rahatsızlıklara özel akıllı filtreleme ve alerjen (glüten) kontrolü.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card h-100 border-0 shadow-sm hover-effect rounded-4">
                    <div class="card-body p-4">
                        <div class="display-4 mb-3">📊</div>
                        <h5 class="card-title fw-bold text-dark">Dinamik Profil Takibi</h5>
                        <p class="card-text text-muted">Hastaların yaş, boy, kilo (VKİ) ve iletişim bilgilerini güvenli veritabanında saklayın ve anlık güncelleyin.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>