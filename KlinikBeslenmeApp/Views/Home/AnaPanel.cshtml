@model KlinikBeslenmeApp.Models.TblHastalar
@{
    ViewBag.Title = "Gösterge Paneli";
}

<div class="container py-4">
    <!-- 1. BÖLÜM: KARŞILAMA -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4 bg-success text-white p-4" style="background: linear-gradient(45deg, #198754, #20c997);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold mb-1">Hoş Geldin, @Model.Ad! 👋</h3>
                        <p class="mb-0 text-white-50">Bugün sağlığın için harika bir gün. İşte sistemin senin için analizleri:</p>
                    </div>
                    <div class="text-end d-none d-md-block">
                        <i class="fas fa-heartbeat fa-3x opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. BÖLÜM: YAPAY ZEKA VE ML ÇIKTILARI (JÜRİ VİTRİNİ) -->
    <div class="row g-4 mb-4">
        <!-- Birliktelik Kuralları (Öneri Motoru) -->
        <div class="col-md-7">
            <div class="card shadow-sm border-0 rounded-4 h-100" style="border-left: 5px solid #0dcaf0 !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="fas fa-robot fa-2x text-info"></i>
                        </div>
                        <h5 class="fw-bold mb-0">AKBİS Karar Destek Sistemi</h5>
                    </div>
                    <p class="text-muted mb-0 lh-lg" style="font-size: 1.05rem;">@ViewBag.YapayZekaOnerisi</p>
                </div>
            </div>
        </div>

        <!-- ML.NET Kilo Tahmini -->
        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-4 h-100" style="border-left: 5px solid #ffc107 !important;">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="fas fa-chart-line fa-2x text-warning"></i>
                        </div>
                        <h5 class="fw-bold mb-0">ML.NET Gelecek Projeksiyonu</h5>
                    </div>
                    <p class="text-muted mb-2">@ViewBag.TahminMesaji</p>
                    @if (ViewBag.GelecekKiloTahmini != null)
                    {
                        <h1 class="fw-bold text-dark mb-0 display-5">@ViewBag.GelecekKiloTahmini <span class="fs-5 text-muted">kg</span></h1>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 3. BÖLÜM: GÜNLÜK ÖZET KARTLARI (MİNİMAL TASARIM) -->
    <div class="row g-4">

        <!-- Kalori Kartı -->
        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 bg-white">
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle" style="width: 60px; height: 60px;">
                            <i class="fas fa-fire fa-2x"></i>
                        </div>
                    </div>
                    <h6 class="text-muted fw-bold">Kalan Kalori</h6>
                    <h2 class="fw-bold text-dark mb-3">@ViewBag.KalanKalori <span class="fs-6 text-muted">kcal</span></h2>
                    <div class="progress rounded-pill" style="height: 8px;">
                        @{
                            double yuzde = ViewBag.HedefKalori > 0 ? (ViewBag.AlinanKalori / ViewBag.HedefKalori) * 100 : 0;
                            string barRenk = yuzde > 100 ? "bg-danger" : "bg-success";
                        }
                        <div class="progress-bar @barRenk" role="progressbar" style="width: @yuzde%" aria-valuenow="@yuzde" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2 text-muted small fw-bold">
                        <span>Alınan: @ViewBag.AlinanKalori</span>
                        <span>Hedef: @ViewBag.HedefKalori</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Su Kartı -->
        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 bg-white hover-effect">
                <div class="card-body position-relative">
                    <!-- Şık Ekleme Butonu (+) -->
                    <button class="btn btn-sm btn-info text-white position-absolute top-0 end-0 m-3 rounded-circle shadow-sm" data-bs-toggle="modal" data-bs-target="#suModal" style="width: 35px; height: 35px; padding: 0;">
                        <i class="fas fa-plus"></i>
                    </button>

                    <div class="mb-3 mt-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-info bg-opacity-10 text-info rounded-circle" style="width: 60px; height: 60px;">
                            <i class="fas fa-tint fa-2x"></i>
                        </div>
                    </div>
                    <h6 class="text-muted fw-bold">İçilen Su</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.BugunSuMililitre <span class="fs-6 text-muted">ml</span></h2>
                </div>
            </div>
        </div>

        <!-- Aktivite Kartı -->
        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 bg-white hover-effect">
                <div class="card-body position-relative">
                    <!-- Şık Ekleme Butonu (+) -->
                    <button class="btn btn-sm btn-warning text-white position-absolute top-0 end-0 m-3 rounded-circle shadow-sm" data-bs-toggle="modal" data-bs-target="#aktiviteModal" style="width: 35px; height: 35px; padding: 0;">
                        <i class="fas fa-plus"></i>
                    </button>

                    <div class="mb-3 mt-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-warning bg-opacity-10 text-warning rounded-circle" style="width: 60px; height: 60px;">
                            <i class="fas fa-running fa-2x"></i>
                        </div>
                    </div>
                    <h6 class="text-muted fw-bold">Yakılan Kalori</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.YakilanKalori <span class="fs-6 text-muted">kcal</span></h2>
                </div>
            </div>
        </div>

        <!-- Öğün Kartı -->
        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0 rounded-4 text-center h-100 bg-white hover-effect">
                <div class="card-body position-relative">
                    <!-- Direkt Öğün Ekleme Sayfasına Gider -->
                    <a href="@Url.Action("YemekGunluguEkle", "Home", new { id = Model.HastaId })" class="btn btn-sm btn-success text-white position-absolute top-0 end-0 m-3 rounded-circle shadow-sm" style="width: 35px; height: 35px; padding: 0; line-height: 35px;">
                        <i class="fas fa-plus"></i>
                    </a>

                    <div class="mb-3 mt-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle" style="width: 60px; height: 60px;">
                            <i class="fas fa-utensils fa-2x"></i>
                        </div>
                    </div>
                    <h6 class="text-muted fw-bold">Bugünkü Öğünler</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.BugunOgunSayisi <span class="fs-6 text-muted">Kayıt</span></h2>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- ================= MODALLAR (GİZLİ PENCERELER) ================= -->
<!-- 1. SU EKLEME MODALI -->
<div class="modal fade" id="suModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header bg-info text-white border-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-tint me-2"></i>Su Tüketimi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("SuEkle", "Home")" method="post">
                <div class="modal-body p-4 text-center">
                    <p class="text-muted mb-3">Ne kadar su içtiğinizi girin.</p>
                    <div class="input-group mb-3">
                        <input type="number" name="miktar" class="form-control text-center fw-bold" step="50" min="50" placeholder="Örn: 200" required>
                        <span class="input-group-text bg-light">ml</span>
                    </div>
                    <!-- Hızlı seçim butonları -->
                    <div class="d-flex justify-content-center gap-2 mb-2">
                        <button type="button" class="btn btn-outline-info btn-sm fw-bold" onclick="document.querySelector('input[name=miktar]').value=200">1 Bardak</button>
                        <button type="button" class="btn btn-outline-info btn-sm fw-bold" onclick="document.querySelector('input[name=miktar]').value=500">1 Şişe</button>
                    </div>
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4 pt-0">
                    <button type="submit" class="btn btn-info text-white fw-bold w-100 rounded-pill">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- 2. AKTİVİTE EKLEME MODALI -->
<div class="modal fade" id="aktiviteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header bg-warning text-dark border-0">
                <h5 class="modal-title fw-bold"><i class="fas fa-running me-2"></i>Aktivite Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="@Url.Action("AktiviteEkle", "Home")" method="post">
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Ne Yaptınız?</label>
                        <select name="AktiviteId" class="form-select form-select-lg" required>
                            <option value="">Aktivite Seçin...</option>
                            @if (ViewBag.Aktiviteler != null)
                            {
                                foreach (var akt in ViewBag.Aktiviteler)
                                {
                                    <option value="@akt.AktiviteId">@akt.AktiviteAdi</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Kaç Dakika Sürdü?</label>
                        <div class="input-group input-group-lg">
                            <input type="number" name="SureDakika" class="form-control" min="1" placeholder="Örn: 45" required>
                            <span class="input-group-text bg-light">dk</span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer justify-content-center border-0 pb-4 pt-0">
                    <button type="submit" class="btn btn-warning fw-bold w-100 rounded-pill">Aktiviteyi Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>