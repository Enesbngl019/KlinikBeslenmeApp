@model KlinikBeslenmeApp.Models.TblHastalar

<style>
    .card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card:hover {
            transform: translateY(-7px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
        }
</style>


<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-primary text-white" style="background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="fw-bold mb-1">👋 Hoş Geldin, @Model.Ad @Model.Soyad!</h2>
                        <p class="mb-0 fs-5">Sağlıklı yaşam hedeflerine bir adım daha yaklaşmak için harika bir gün.</p>
                    </div>
                    <div class="text-end d-none d-md-block">
                        <span class="badge bg-light text-primary fs-6 px-3 py-2">Klinik Profil: Aktif</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0" style="border-radius: 15px; background: linear-gradient(135deg, #f3e8ff, #ffffff); border-left: 5px solid #8b5cf6 !important;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-white p-3 rounded-circle shadow-sm me-3">
                            <i class="bi bi-envelope-paper-heart-fill fs-3" style="color: #8b5cf6;"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">Diyetisyeninizin Mesajı Var!</h5>
                            <p class="mb-0 text-muted small">Bu not size özel olarak hazırlanmıştır.</p>
                        </div>
                    </div>

                    <div class="p-3 bg-white rounded shadow-sm border" style="border-color: #ede9fe !important;">
                        @if (!string.IsNullOrEmpty(Model.DoktorNotu))
                        {
                            <p class="mb-0 fw-bold" style="color: #4c1d95; font-size: 1.1rem; white-space: pre-line;">
                                <i class="bi bi-quote fs-4 text-muted opacity-50"></i> @Model.DoktorNotu
                            </p>
                        }
                        else
                        {
                            <p class="mb-0 text-muted fst-italic">
                                <i class="bi bi-hourglass-split"></i> Doktorunuz henüz size özel bir diyet programı veya not eklememiş. Poliklinik onay süreciniz tamamlandığında burası güncellenecektir.
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4 mt-3">
        <div class="col-md-4 mb-3">
            <div class="card bg-primary text-white shadow rounded-4 border-0 h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="display-4 me-3"><i class="bi bi-calendar2-check"></i></div>
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">Bugünkü Öğün</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.BugunOgunSayisi <span class="fs-6 fw-normal">Kez</span></h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card bg-success text-white shadow rounded-4 border-0 h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="display-4 me-3"><i class="bi bi-egg-fried"></i></div>
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">Toplam Çeşit</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.BugunCesitSayisi <span class="fs-6 fw-normal">Farklı</span></h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card bg-warning text-dark shadow rounded-4 border-0 h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="display-4 me-3"><i class="bi bi-pie-chart"></i></div>
                    <div>
                        <h6 class="text-uppercase mb-1 opacity-75">Toplam Porsiyon</h6>
                        <h2 class="mb-0 fw-bold">@ViewBag.BugunPorsiyon <span class="fs-6 fw-normal">Pors.</span></h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.ColyakMi == true || Model.DiyabetMi == true || Model.TansiyonHastasiMi == true)
    {
        <div class="alert alert-warning shadow-sm border-start border-warning border-5 mb-4" role="alert">
            <h5 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill text-warning"></i> Klinik Uyarı Sisteminiz</h5>
            <hr>
            <p class="mb-0">
                Sistemimiz;
                @if (Model.ColyakMi == true)
                {
                    <strong class="text-danger">Çölyak (Glütensiz)</strong>
                }
                @if (Model.DiyabetMi == true)
                {
                    <strong class="text-danger">Diyabet</strong>
                }
                @if (Model.TansiyonHastasiMi == true)
                {
                    <strong class="text-danger">Hipertansiyon</strong>
                }
                profilinize uygun olarak reçetelerinizi ve alerjen bildirimlerinizi otomatik filtrelemektedir.
            </p>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-0 text-center">
                <div class="card-body py-4">
                    <div class="display-3 mb-2">⚖️</div>
                    <h5 class="text-muted fw-bold">Vücut Kitle İndeksi</h5>
                    @if (Model.Boy != null && Model.Kilo != null && Model.Boy > 0)
                    {
                        double boyMetre = Convert.ToDouble(Model.Boy) / 100.0;
                        double vki = Convert.ToDouble(Model.Kilo) / (boyMetre * boyMetre);
                        double yuvarlanmisVki = Math.Round(vki, 1);

                        string durum = yuvarlanmisVki < 18.5 ? "Zayıf" : (yuvarlanmisVki <= 24.9 ? "Normal" : (yuvarlanmisVki <= 29.9 ? "Fazla Kilolu" : "Obez"));
                        string renk = yuvarlanmisVki <= 24.9 ? "success" : (yuvarlanmisVki < 18.5 ? "warning" : "danger");

                        <h2 class="display-5 fw-bold text-@renk mt-3 mb-1">@yuvarlanmisVki</h2>
                        <h6 class="text-muted">Durum: <span class="badge bg-@renk fs-6">@durum</span></h6>
                    }
                    else
                    {
                        <p class="text-danger fw-bold mt-3">Lütfen profilinizden boy ve kilonuzu güncelleyin.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-0 text-center">
                <div class="card-body py-4">
                    <div class="display-3 mb-2">🍎</div>
                    <h5 class="text-muted fw-bold">Bugünkü Menüm</h5>
                    <p class="text-secondary mt-3">Klinik değerlerinize özel hazırlanan günlük yemek listenize ulaşın.</p>
                    <a asp-action="YemekGunluguEkle" asp-controller="Home" asp-route-id="@Model.HastaId" class="btn btn-primary fw-bold w-100 mt-2 shadow-sm">
                        <i class="bi bi-pencil-square"></i> Ne Yedin? (Günlüğe Ekle)
                    </a>
                    <a asp-action="GunlukMenu" asp-controller="Home" asp-route-id="@Model.HastaId" class="btn btn-outline-success fw-bold w-100 mt-2 shadow-sm">
                        Menüyü Görüntüle 🚀
                    </a>
                    <a asp-action="YemekGecmisi" asp-controller="Home" asp-route-id="@Model.HastaId" class="btn btn-outline-dark fw-bold w-100 mt-2 shadow-sm">
                        <i class="bi bi-calendar-check"></i> Yemek Geçmişim
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-0 text-center bg-light">
                <div class="card-body py-4">
                    <div class="display-3 mb-2">⚙️</div>
                    <h5 class="text-muted fw-bold">Hesap Yönetimi</h5>
                    <p class="text-secondary mt-3">Kişisel bilgilerinizi, adresinizi ve klinik ölçümlerinizi güncelleyin.</p>
                    <div class="d-grid gap-2 mt-2">
                        <a asp-action="Profilim" asp-controller="Home" asp-route-id="@Model.HastaId" class="btn btn-primary fw-bold">Profilime Git</a>
                        <a asp-action="ProfilDuzenle" asp-controller="Home" asp-route-id="@Model.HastaId" class="btn btn-outline-secondary fw-bold">Düzenle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>