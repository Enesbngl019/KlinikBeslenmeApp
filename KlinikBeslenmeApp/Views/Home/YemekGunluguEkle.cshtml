@model KlinikBeslenmeApp.Models.TblYemekGunlugu
@{
    ViewBag.Title = "Yeni Öğün Ekle";
}

<div class="container mt-5 mb-5" style="max-width: 700px;">
    <div class="card shadow-lg border-0" style="border-radius: 15px;">
        <div class="card-header bg-primary text-white text-center py-3" style="border-radius: 15px 15px 0 0;">
            <h4 class="mb-0"><i class="bi bi-journal-plus"></i> Yemek Günlüğüm</h4>
        </div>
        <div class="card-body p-4 text-center">
            <p class="text-muted">Sevgili <strong>@ViewBag.HastaAd</strong>, yediğin öğünü kaydederek gelişimini takip edebiliriz.</p>

            <form asp-action="YemekGunluguEkle" method="post">
                <input type="hidden" asp-for="HastaId" value="@ViewBag.HastaId" />

                <div class="mb-4 text-start">
                    <label class="fw-bold text-secondary mb-1">Ne Zaman Yedin?</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-primary text-white"><i class="bi bi-calendar-check"></i></span>
                        <input type="datetime-local" name="ozelTarih" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required>
                    </div>
                </div>

                <div class="mb-4 text-start">
                    <label class="fw-bold text-dark mb-1">Hangi Öğün?</label>
                    <select asp-for="OgunTipi" class="form-select form-select-lg" required>
                        <option value="">-- Öğün Seç --</option>
                        <option value="Kahvaltı">☀️ Kahvaltı</option>
                        <option value="Öğle Yemeği">🌤️ Öğle Yemeği</option>
                        <option value="Ara Öğün">🍎 Ara Öğün</option>
                        <option value="Akşam Yemeği">🌙 Akşam Yemeği</option>
                        <option value="Gece Atıştırmalığı">🍟 Gece Atıştırmalığı</option>
                    </select>
                </div>

                <div class="mb-4 text-start">
                    <label class="fw-bold text-dark mb-1">Ne Yedin?</label>

                    <div id="yemeklerContainer">
                        <div class="yemek-satiri mb-2 d-flex align-items-center shadow-sm rounded">
                            <select name="secilenYemekler" class="form-select form-select-lg yemek-secici" onchange="kaloriGuncelle(this)" required>
                                <option value="" data-kalori="0">-- Listeden Yemek Seç --</option>
                                @foreach (var yemek in ViewBag.Yemekler)
                                {
                                    <option value="@yemek.YemekId" data-kalori="@ViewBag.Kaloriler[yemek.YemekId]">
                                        @yemek.YemekAdi (@yemek.Kategori)
                                    </option>
                                }
                            </select>

                            <select name="secilenPorsiyonlar" class="form-select porsiyon-secici ms-2" style="max-width: 140px;" onchange="kaloriGuncelle(this)" required>
                                <option value="0.25">Çeyrek</option>
                                <option value="0.5">Yarım</option>
                                <option value="1" selected>1 Porsiyon</option>
                                <option value="1.5">1.5 Porsiyon</option>
                                <option value="2">Duble (2x)</option>
                            </select>

                            <span class="badge bg-warning text-dark ms-2 kalori-etiketi shadow-sm" style="min-width: 85px; font-size: 1rem;">0 kcal</span>
                        </div>
                    </div>

                    <button type="button" class="btn btn-sm btn-outline-primary fw-bold mt-2 shadow-sm" onclick="yeniYemekSatiriEkle()">
                        <i class="bi bi-plus-circle"></i> Başka Bir Yemek Daha Ekle
                    </button>
                </div>

                <div id="oneriKarti" class="alert shadow-sm mt-3 text-start" style="display:none; border-left: 5px solid #0dcaf0; background-color: #f8f9fa;">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-robot fs-2 text-info me-3"></i>
                        <h5 class="alert-heading mb-0 fw-bold text-dark">AKBİS Akıllı Öneri</h5>
                    </div>
                    <hr>
                    <p class="mb-0 text-muted" id="oneriMetni"></p>
                </div>

                <div class="mb-4 text-start mt-4">
                    <label class="fw-bold text-dark mb-1">Açıklama / Doktora Not</label>
                    <textarea asp-for="Aciklama" class="form-control" rows="2" placeholder="Örn: Tatlıyı dayanamayıp tam porsiyon yedim..."></textarea>
                </div>

                <div class="alert alert-success d-flex justify-content-between align-items-center mb-4 shadow-sm">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-activity"></i> Toplam Kalori:</h5>
                    <h4 class="mb-0 fw-bold text-danger"><span id="toplamKaloriSonuc">0</span> kcal</h4>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                        <i class="bi bi-check2-circle"></i> Öğünü Kaydet
                    </button>
                    <a href="@Url.Action("AnaPanel", new { id = ViewBag.HastaId })" class="btn btn-outline-secondary">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function kaloriGuncelle(tetikleyenElement) {
            var satir = tetikleyenElement.closest('.yemek-satiri');
            var yemekSecici = satir.querySelector('.yemek-secici');
            var porsiyonSecici = satir.querySelector('.porsiyon-secici');
            var etiket = satir.querySelector('.kalori-etiketi');

            var secilenOption = yemekSecici.options[yemekSecici.selectedIndex];
            var bazKalori = parseFloat(secilenOption.getAttribute('data-kalori')) || 0;
            var porsiyonCarpani = parseFloat(porsiyonSecici.value) || 1;

            var gercekKalori = Math.round(bazKalori * porsiyonCarpani);

            etiket.innerText = gercekKalori + " kcal";
            genelToplamiHesapla();
        }

        function genelToplamiHesapla() {
            var toplam = 0;
            var butunSatirlar = document.querySelectorAll('.yemek-satiri');

            butunSatirlar.forEach(function(satir) {
                var yemekSecici = satir.querySelector('.yemek-secici');
                var porsiyonSecici = satir.querySelector('.porsiyon-secici');

                var secilenOption = yemekSecici.options[yemekSecici.selectedIndex];
                if(secilenOption.value !== "") {
                    var bazKalori = parseFloat(secilenOption.getAttribute('data-kalori')) || 0;
                    var porsiyonCarpani = parseFloat(porsiyonSecici.value) || 1;
                    toplam += (bazKalori * porsiyonCarpani);
                }
            });

            document.getElementById('toplamKaloriSonuc').innerText = Math.round(toplam);
        }

        function yeniYemekSatiriEkle() {
            var container = document.getElementById("yemeklerContainer");
            var ilkSatir = document.querySelector(".yemek-satiri");

            var yeniSatir = ilkSatir.cloneNode(true);
            var yemekSecici = yeniSatir.querySelector(".yemek-secici");
            var porsiyonSecici = yeniSatir.querySelector(".porsiyon-secici");
            var kaloriEtiketi = yeniSatir.querySelector(".kalori-etiketi");

            yemekSecici.value = "";
            porsiyonSecici.value = "1";
            kaloriEtiketi.innerText = "0 kcal";

            var silButonu = document.createElement("button");
            silButonu.type = "button";
            silButonu.className = "btn btn-danger ms-2 shadow-sm";
            silButonu.innerHTML = "<i class='bi bi-trash'></i>";

            silButonu.onclick = function() {
                container.removeChild(yeniSatir);
                genelToplamiHesapla();
            };

            yeniSatir.appendChild(silButonu);
            container.appendChild(yeniSatir);
        }

        $(document).ready(function () {
            $(document).on('change', '.yemek-secici', function () {
                var secilenId = $(this).val();

                var secilenYemekAd = $(this).find("option:selected").text().split('(')[0].trim();

                if (secilenId === "") {
                    $("#oneriKarti").slideUp();
                    return;
                }

                $("#oneriMetni").html("<i class='spinner-border spinner-border-sm'></i> Algoritmalar analiz ediyor...");
                $("#oneriKarti").slideDown();

                $.ajax({
                    url: '/Home/OneriGetir', 
                    type: 'GET',
                    data: { yemekId: secilenId },
                    success: function (response) {
                        if (response.basarili) {
                            $("#oneriMetni").html(response.oneriMesaji);
                        } else {
                            $("#oneriMetni").html("Verilerimize göre <b>" + secilenYemekAd + "</b> tercih eden diğer hastalarımız, öğünlerini genellikle düşük glisemik indeksli yancılarla dengelemektedir.");
                        }
                    },
                    error: function () {
                        $("#oneriMetni").html("Verilerimize göre <b>" + secilenYemekAd + "</b> tercih eden diğer hastalarımız, öğünlerini sağlıklı yeşilliklerle dengelemektedir. Menünüze ekleyebilirsiniz.");
                    }
                });
            });
        });
    </script>
}