@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AKBİS - Yetkili Girişi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-dark text-white d-flex align-items-center justify-content-center vh-100">

    <div class="card bg-secondary bg-opacity-25 border-0 shadow-lg p-5 rounded-4" style="width: 400px; backdrop-filter: blur(10px);">
        <div class="text-center mb-4">
            <i class="fas fa-user-shield fa-4x text-warning mb-3"></i>
            <h3 class="fw-bold">Sistem Yöneticisi</h3>
            <p class="text-white-50">Yetkili portalına giriş yapın</p>
        </div>

        @if (ViewBag.Hata != null)
        {
            <div class="alert alert-danger small text-center rounded-3">@ViewBag.Hata</div>
        }

        <form asp-action="AdminGiris" asp-controller="Home" method="post">
            <div class="mb-3">
                <div class="input-group">
                    <span class="input-group-text bg-dark text-white border-secondary"><i class="fas fa-envelope"></i></span>
                    <input type="email" name="Email" class="form-control bg-dark text-white border-secondary" placeholder="Yönetici E-Posta" required>
                </div>
            </div>
            <div class="mb-4">
                <div class="input-group">
                    <span class="input-group-text bg-dark text-white border-secondary"><i class="fas fa-lock"></i></span>
                    <input type="password" name="Sifre" class="form-control bg-dark text-white border-secondary" placeholder="Şifre" required>
                </div>
            </div>
            <button type="submit" class="btn btn-warning w-100 fw-bold rounded-pill">Sisteme Giriş Yap</button>
            <a href="@Url.Action("GirisYap", "Home")" class="btn btn-outline-light w-100 fw-bold rounded-pill mt-3">Geri Dön</a>
        </form>
    </div>

</body>
</html>